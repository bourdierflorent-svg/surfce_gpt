# Application
NEXT_PUBLIC_APP_URL=https://surfce-gpt.vercel.app
APP_ENCRYPTION_KEY=
CRON_SECRET=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_URL=

# AI (la Phase 4 utilise mock par défaut)
AI_PROVIDER=mock
OPENAI_API_KEY=
AI_DEFAULT_MODEL=

# Map (provider réel optionnel, non utilisé par la Phase 3 mock)
NEXT_PUBLIC_MAP_STYLE_URL=
MAP_TILES_API_KEY=

# Places (provider réel optionnel, la Phase 3 utilise mock)
PLACES_PROVIDER=mock
GOOGLE_MAPS_API_KEY=
OVERTURE_DATA_URL=

# Company registry (la Phase 4 utilise mock par défaut)
COMPANY_REGISTRY_PROVIDER=mock
SIRENE_API_KEY=
SIRENE_API_BASE_URL=

# Contact verification (Phase 5 uses mock by default)
CONTACT_VERIFICATION_PROVIDER=mock
HUNTER_API_KEY=
DROPCONTACT_API_KEY=

# Mail (mock remains available; Google and Microsoft require OAuth below)
MAIL_PROVIDER=mock
MAIL_WEBHOOK_SECRET=

# Gmail (Phase 6)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://surfce-gpt.vercel.app/api/oauth/google/callback
GOOGLE_PUBSUB_TOPIC=
GOOGLE_WEBHOOK_SECRET=

# Microsoft (phase 6)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
MICROSOFT_REDIRECT_URI=https://surfce-gpt.vercel.app/api/oauth/microsoft/callback
MICROSOFT_WEBHOOK_CLIENT_STATE=

# Optional external monitoring (reserved; structured logs work without it)
SENTRY_DSN=

# E2E authenticated checks (local/CI only; never configure these in Vercel runtime)
E2E_BASE_URL=
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
